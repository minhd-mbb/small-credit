generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  BANK_ADMIN
  ACCOUNT
}

enum AccountType {
  CHECKING
  SAVINGS
  LOAN
  PLEDGE
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  INTEREST
  FEE
  REPAYMENT
}

enum LoanStatus {
  PENDING
  ACTIVE
  OVERDUE
  CLOSED
}

enum SavingInterestPolicyType {
  BASIC
  PERIOD
  PROMOTIONAL
}

enum LoanInterestPolicyType {
  BASIC
  TERM
}

enum FundType {
  SYSTEM
  BANK
}

enum StockTradeType {
  BUY
  SELL
}

model Bank {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  accounts Account[]
  savingInterestPolicies SavingInterestPolicy[]
  loanInterestPolicies LoanInterestPolicy[]
  fund Fund?
  stockCrawlerSetting StockCrawlerSetting?
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  fullName     String   @db.VarChar(100)
  phone        String?  @unique
  email        String?  @unique
  passwordHash String
  role         Role     @default(ACCOUNT)
  bankId       String?
  isActive     Boolean  @default(true)
  resetPasswordRequested Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bank     Bank?    @relation(fields: [bankId], references: [id])
  accounts Account[]
  loans    Loan[]
  pledges  Pledge[]
  sessions Session[]
  stockWatchlistItems StockWatchlistItem[]
  stockSyncRawLogs StockSyncRawLog[]
  stockHoldings StockHolding[]
  stockTrades StockTrade[]
}

model ActivityLog {
  id           String   @id @default(cuid())
  username     String
  action       String
  time         DateTime @default(now())
  functionName String   @default("General")
  beforeChange Json?
  afterChange  Json?

  @@index([username, time])
  @@index([time])
}

model Account {
  id        String      @id @default(cuid())
  accountNo String      @unique
  userId    String
  bankId    String?
  type      AccountType @default(CHECKING)
  balance   Decimal     @default(0) @db.Decimal(18, 2)
  currency  String      @default("VND")
  status    String      @default("ACTIVE")
  openedAt  DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  bank         Bank?         @relation(fields: [bankId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  savings      Saving[]
  loans        Loan[]
  stockHoldings StockHolding[]
  stockTrades StockTrade[]
  overdraft    Overdraft?
  dashboardCache AccountDashboardCache?
}

model Transaction {
  id           String          @id @default(cuid())
  accountId    String
  type         TransactionType
  amount       Decimal         @db.Decimal(18, 2)
  balanceAfter Decimal         @db.Decimal(18, 2)
  description  String?
  refId        String?
  refType      String?
  createdBy    String?
  txnAt        DateTime        @default(now())

  account Account @relation(fields: [accountId], references: [id])
}

model AccountDashboardCache {
  id           String   @id @default(cuid())
  accountId    String   @unique
  userId       String
  payload      Json
  calculatedAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Saving {
  id                      String    @id @default(cuid())
  accountId               String
  principal               Decimal   @db.Decimal(18, 2)
  principalInitial        Decimal   @default(0) @db.Decimal(18, 2)
  principalRemaining      Decimal   @default(0) @db.Decimal(18, 2)
  interestRate            Decimal   @db.Decimal(5, 2)
  basicInterestRateAtOpen Decimal   @default(0) @db.Decimal(5, 2)
  termMonths              Int
  termType                String    @default("FIXED")
  startDate               DateTime
  maturityDate            DateTime
  accruedInterest         Decimal   @default(0) @db.Decimal(18, 2)
  lastAccruedAt           DateTime?
  status                  String    @default("ACTIVE")
  closedAt                DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  account       Account               @relation(fields: [accountId], references: [id])
  accruals      SavingDailyAccrual[]
  withdrawals   SavingWithdrawal[]
  rateChanges   SavingRateChange[]
  historyEvents SavingHistory[]

  @@index([accountId, status])
  @@index([maturityDate])
}

model SavingDailyAccrual {
  id                   String   @id @default(cuid())
  savingId             String
  accrualDate          DateTime
  principal            Decimal  @db.Decimal(18, 2)
  annualRatePercent    Decimal  @db.Decimal(5, 2)
  interestAmount       Decimal  @db.Decimal(18, 2)
  accruedInterestAfter Decimal  @db.Decimal(18, 2)
  createdAt            DateTime @default(now())

  saving Saving @relation(fields: [savingId], references: [id], onDelete: Cascade)

  @@unique([savingId, accrualDate])
  @@index([accrualDate])
}

model SavingWithdrawal {
  id                     String   @id @default(cuid())
  savingId               String
  type                   String
  withdrawPrincipal      Decimal  @db.Decimal(18, 2)
  interestPaid           Decimal  @db.Decimal(18, 2)
  rateApplied            Decimal  @db.Decimal(5, 2)
  balancePrincipalAfter  Decimal  @db.Decimal(18, 2)
  refId                  String
  withdrawnAt            DateTime @default(now())

  saving Saving @relation(fields: [savingId], references: [id], onDelete: Cascade)

  @@index([savingId, withdrawnAt])
}

model SavingRateChange {
  id            String   @id @default(cuid())
  savingId      String
  oldRate       Decimal  @db.Decimal(5, 2)
  newRate       Decimal  @db.Decimal(5, 2)
  effectiveDate DateTime
  changedBy     String
  createdAt     DateTime @default(now())

  saving Saving @relation(fields: [savingId], references: [id], onDelete: Cascade)

  @@index([savingId, effectiveDate])
}

model SavingHistory {
  id                    String   @id @default(cuid())
  savingId              String
  action                String
  principalChange       Decimal? @db.Decimal(18, 2)
  interestChange        Decimal? @db.Decimal(18, 2)
  principalBalanceAfter Decimal? @db.Decimal(18, 2)
  note                  String?
  createdAt             DateTime @default(now())

  saving Saving @relation(fields: [savingId], references: [id], onDelete: Cascade)

  @@index([savingId, createdAt])
}

model SavingInterestPolicy {
  id                String                   @id @default(cuid())
  bankId            String
  type              SavingInterestPolicyType
  annualRatePercent Decimal                  @db.Decimal(5, 2)
  startDate         DateTime?
  endDate           DateTime?
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  bank Bank @relation(fields: [bankId], references: [id])

  @@index([bankId, type, isActive])
  @@index([startDate, endDate])
}

model SystemSavingBaseRate {
  id                String   @id @default("SYSTEM_SAVING_BASE_RATE")
  annualRatePercent Decimal  @db.Decimal(5, 2)
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SystemLoanBaseRate {
  id                String   @id @default("SYSTEM_LOAN_BASE_RATE")
  annualRatePercent Decimal  @db.Decimal(5, 2)
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LoanInterestPolicy {
  id                String                 @id @default(cuid())
  bankId            String
  type              LoanInterestPolicyType
  annualRatePercent Decimal                @db.Decimal(5, 2)
  termMonths        Int?
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  bank Bank @relation(fields: [bankId], references: [id])

  @@index([bankId, type, isActive])
  @@index([termMonths])
}

model Fund {
  id        String   @id @default(cuid())
  type      FundType
  bankId    String?  @unique
  name      String
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bank         Bank?             @relation(fields: [bankId], references: [id])
  transactions FundTransaction[]

  @@index([type])
}

model FundTransaction {
  id          String   @id @default(cuid())
  fundId      String
  type        String
  amount      Decimal  @db.Decimal(18, 2)
  balanceAfter Decimal @db.Decimal(18, 2)
  reason      String
  refId       String?
  createdBy   String
  createdAt   DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, createdAt])
}

model Loan {
  id                      String     @id @default(cuid())
  userId                  String
  accountId               String
  principal               Decimal    @db.Decimal(18, 2)
  principalInitial        Decimal    @default(0) @db.Decimal(18, 2)
  principalRemaining      Decimal    @default(0) @db.Decimal(18, 2)
  interestRate            Decimal    @db.Decimal(5, 2)
  basicInterestRateAtOpen Decimal    @default(0) @db.Decimal(5, 2)
  termMonths              Int
  interestType            String     @default("FIXED")
  startDate               DateTime   @default(now())
  maturityDate            DateTime?
  disbursedAt             DateTime?
  dueDate                 DateTime?
  accruedInterest         Decimal    @default(0) @db.Decimal(18, 2)
  lastAccruedAt           DateTime?
  outstanding             Decimal    @db.Decimal(18, 2)
  status                  LoanStatus @default(PENDING)
  note                    String?
  closedAt                DateTime?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  user          User               @relation(fields: [userId], references: [id])
  account       Account            @relation(fields: [accountId], references: [id])
  schedules     LoanSchedule[]
  accruals      LoanDailyAccrual[]
  repayments    LoanRepayment[]
  rateChanges   LoanRateChange[]
  historyEvents LoanHistory[]

  @@index([accountId, status])
  @@index([maturityDate])
}

model LoanDailyAccrual {
  id                   String   @id @default(cuid())
  loanId               String
  accrualDate          DateTime
  principal            Decimal  @db.Decimal(18, 2)
  annualRatePercent    Decimal  @db.Decimal(5, 2)
  interestAmount       Decimal  @db.Decimal(18, 2)
  accruedInterestAfter Decimal  @db.Decimal(18, 2)
  createdAt            DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, accrualDate])
  @@index([accrualDate])
}

model LoanRepayment {
  id                    String   @id @default(cuid())
  loanId                String
  principalPaid         Decimal  @db.Decimal(18, 2)
  interestPaid          Decimal  @db.Decimal(18, 2)
  totalPaid             Decimal  @db.Decimal(18, 2)
  principalBalanceAfter Decimal  @db.Decimal(18, 2)
  interestBalanceAfter  Decimal  @db.Decimal(18, 2)
  refId                 String
  paidAt                DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, paidAt])
}

model LoanRateChange {
  id            String   @id @default(cuid())
  loanId        String
  oldRate       Decimal  @db.Decimal(5, 2)
  newRate       Decimal  @db.Decimal(5, 2)
  effectiveDate DateTime
  changedBy     String
  createdAt     DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, effectiveDate])
}

model LoanHistory {
  id                    String   @id @default(cuid())
  loanId                String
  action                String
  principalChange       Decimal? @db.Decimal(18, 2)
  interestChange        Decimal? @db.Decimal(18, 2)
  principalBalanceAfter Decimal? @db.Decimal(18, 2)
  interestBalanceAfter  Decimal? @db.Decimal(18, 2)
  note                  String?
  createdAt             DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, createdAt])
}

model LoanSchedule {
  id            String    @id @default(cuid())
  loanId        String
  installmentNo Int
  dueDate       DateTime
  principalDue  Decimal   @db.Decimal(18, 2)
  interestDue   Decimal   @db.Decimal(18, 2)
  paidAmount    Decimal   @default(0) @db.Decimal(18, 2)
  paidAt        DateTime?
  status        String    @default("PENDING")

  loan Loan @relation(fields: [loanId], references: [id])
}

model Pledge {
  id           String   @id @default(cuid())
  userId       String
  accountId    String
  assetType    String
  assetDesc    String
  assetValue   Decimal  @db.Decimal(18, 2)
  loanAmount   Decimal  @db.Decimal(18, 2)
  interestRate Decimal  @db.Decimal(5, 4)
  startDate    DateTime
  endDate      DateTime
  status       String   @default("ACTIVE")
  imageUrls    String[]
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Overdraft {
  id           String   @id @default(cuid())
  accountId    String   @unique
  limitAmount  Decimal  @db.Decimal(18, 2)
  usedAmount   Decimal  @default(0) @db.Decimal(18, 2)
  interestRate Decimal  @db.Decimal(5, 4)
  status       String   @default("ACTIVE")
  approvedAt   DateTime @default(now())
  expiresAt    DateTime

  account Account @relation(fields: [accountId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StockWatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  symbol    String   @db.VarChar(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId, createdAt])
}

model StockPriceCache {
  symbol        String   @id @db.VarChar(10)
  companyName   String?
  price         Decimal? @db.Decimal(18, 4)
  changePercent Decimal? @db.Decimal(8, 4)
  source        String   @default("PLAYWRIGHT")
  raw           Json?
  syncedAt      DateTime?
  updatedAt     DateTime @updatedAt
}

model StockCrawlerSetting {
  id             String   @id @default(cuid())
  bankId         String   @unique
  urlTemplate    String   @default("https://finance.vietstock.vn/{symbol}/thong-ke-giao-dich.htm") @db.VarChar(500)
  timeoutMs      Int      @default(12000)
  maxRawLogs     Int      @default(20)
  waitAfterLoadMs Int     @default(3000)
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)
}

model StockSyncRawLog {
  id          String   @id @default(cuid())
  userId      String
  bankId      String?
  symbol      String   @db.VarChar(10)
  pageUrl     String   @db.VarChar(800)
  responseUrl String   @db.VarChar(1000)
  status      Int?
  contentType String?
  extracted   Boolean  @default(false)
  raw         Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([symbol, createdAt])
}

model StockHolding {
  id               String   @id @default(cuid())
  userId           String
  accountId        String
  bankId           String?
  symbol           String   @db.VarChar(10)
  quantity         Int
  averageCostPrice Decimal  @db.Decimal(18, 4)
  totalCost        Decimal  @db.Decimal(18, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([accountId])
  @@index([bankId])
}

model StockTrade {
  id            String         @id @default(cuid())
  userId        String
  accountId     String
  bankId        String?
  symbol        String         @db.VarChar(10)
  type          StockTradeType
  quantity      Int
  price         Decimal        @db.Decimal(18, 4)
  grossAmount   Decimal        @db.Decimal(18, 2)
  feeAmount     Decimal        @db.Decimal(18, 2)
  netAmount     Decimal        @db.Decimal(18, 2)
  balanceAfter  Decimal        @db.Decimal(18, 2)
  refId         String
  createdAt     DateTime       @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([symbol, createdAt])
}
